<resources>
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#8D5524</item>
        <item name="colorPrimaryDark">#6B3E1C</item>
        <item name="colorAccent">#F28C38</item>
        <item name="android:background">#FFF8E7</item>
        <item name="android:textColorPrimary">#4A2F1A</item>
        <item name="android:textColorSecondary">#7A5A3F</item>
        <item name="android:editTextColor">#4A2F1A</item>
        <item name="android:textColorHint">#7A5A3F</item>
    </style>

    <style name="AppButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:background">@drawable/button_background</item>
        <item name="android:textColor">#FFF8E7</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
    </style>

    <style name="AppButton.Outlined">
        <item name="android:minHeight">48dp</item>
        <item name="android:background">@drawable/button_outlined_background</item>
        <item name="android:textColor">#8D5524</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
    </style>
</resources>